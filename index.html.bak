<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;600;700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #1a1b6e;
    --navy-dark: #11124a;
    --navy-light: #252699;
    --pink: #e91e8c;
    --pink-light: #ff4da6;
    --green: #39e639;
    --green-light: #66ff66;
    --white: #ffffff;
    --off-white: #f0f0ff;
    --gold: #ffd700;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--navy-dark);
    color: var(--white);
    overflow-x: hidden;
    font-size: 18px;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 3rem;
    background: rgba(17, 18, 74, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(233,30,140,0.2);
  }

  .nav-logo {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    background: linear-gradient(90deg, var(--pink), var(--green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--green); }

  .nav-cta {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--pink);
    color: white;
    border: none;
    padding: 0.6rem 1.4rem;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.1s;
  }

  .nav-cta:hover { background: var(--pink-light); transform: translateY(-1px); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("data:image/webp;base64,");
    background-size: cover;
    background-position: center;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(17, 18, 74, 0.78);
  }

  /* starfield */
  .stars { display: none; }

  .star {
    position: absolute;
    border-radius: 50%;
    background: white;
    animation: twinkle var(--d, 3s) infinite ease-in-out alternate;
    opacity: 0.4;
  }

  @keyframes twinkle {
    from { opacity: 0.1; transform: scale(0.8); }
    to   { opacity: 0.7; transform: scale(1.2); }
  }

  .starburst {
    display: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 1.2rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.2s forwards;
  }

  .hero-title {
    font-family: 'Bebas Neue', cursive;
    line-height: 0.9;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.4s forwards;
  }

  .hero-title .line1 {
    font-size: clamp(4rem, 12vw, 9rem);
    color: var(--pink);
    display: block;
    text-shadow: 0 0 60px rgba(233,30,140,0.4);
  }

  .hero-title .line2 {
    font-size: clamp(4rem, 12vw, 9rem);
    color: var(--green);
    display: block;
    text-shadow: 0 0 60px rgba(57,230,57,0.4);
    letter-spacing: 0.04em;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    opacity: 0;
    animation: fadeUp 0.7s 0.6s forwards;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.7s 0.8s forwards;
  }

  .btn-primary {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--pink);
    color: white;
    border: none;
    padding: 1rem 2.2rem;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 24px rgba(233,30,140,0.35);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(233,30,140,0.5);
  }

  .btn-outline {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: transparent;
    color: var(--green);
    border: 2px solid var(--green);
    padding: 1rem 2.2rem;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, transform 0.15s;
  }

  .btn-outline:hover {
    background: rgba(57,230,57,0.1);
    transform: translateY(-2px);
  }

  .hero-dice { display: none; }

  @keyframes float {
    from { transform: translateY(0) rotate(0deg); }
    to   { transform: translateY(-20px) rotate(15deg); }
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    opacity: 0.4;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: pulse 2s infinite;
  }

  .scroll-hint-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--green), transparent);
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SECTION BASE ── */
  section {
    padding: 6rem 2rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pink);
    margin-bottom: 0.8rem;
  }

  .section-title {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
  }

  .section-title .accent-green { color: var(--green); }
  .section-title .accent-pink  { color: var(--pink); }

  /* ── WHY / MISSION ── */
  .why {
    background: var(--navy);
    border-top: 1px solid rgba(57,230,57,0.15);
    border-bottom: 1px solid rgba(233,30,140,0.15);
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .why-text p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.75);
    margin-bottom: 1rem;
  }

  .why-text p strong {
    color: var(--green);
    font-weight: 600;
  }

  .why-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .pillar {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(57,230,57,0.15);
    border-radius: 6px;
    padding: 1.2rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .pillar:hover {
    border-color: rgba(57,230,57,0.4);
    background: rgba(57,230,57,0.06);
  }

  .pillar-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .pillar h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 0.3rem;
  }

  .pillar p {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.5;
  }

  /* ── EVENTS ── */
  .events { background: var(--navy-dark); }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .event-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
    cursor: pointer;
  }

  .event-card:hover {
    transform: translateY(-4px);
    border-color: rgba(233,30,140,0.4);
  }

  .event-card-header {
    padding: 1.5rem 1.5rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: relative;
  }

  .event-tag {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 3px;
    margin-bottom: 0.8rem;
  }

  .tag-tournament { background: rgba(233,30,140,0.15); color: var(--pink); border: 1px solid rgba(233,30,140,0.3); }
  .tag-open-play  { background: rgba(57,230,57,0.1); color: var(--green); border: 1px solid rgba(57,230,57,0.3); }
  .tag-lessons    { background: rgba(255,215,0,0.1); color: var(--gold); border: 1px solid rgba(255,215,0,0.25); }
  .tag-charity    { background: rgba(176,134,255,0.12); color: #c8a8ff; border: 1px solid rgba(176,134,255,0.3); }
  .tag-special    { background: rgba(255,165,0,0.1); color: #ffb347; border: 1px solid rgba(255,165,0,0.3); }

  .event-card-header h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.3rem;
  }

  .event-meta {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }

  .event-card-body {
    padding: 1rem 1.5rem 1.5rem;
  }

  .event-card-body p {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .event-price {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .price-amount {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.8rem;
    color: var(--green);
  }

  .price-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
  }

  .btn-card {
    display: block;
    width: 100%;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: transparent;
    color: var(--pink);
    border: 1px solid var(--pink);
    padding: 0.7rem;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn-card:hover { background: rgba(233,30,140,0.12); }

  /* ── CLASSES ── */
  .classes {
    background: var(--navy);
    border-top: 1px solid rgba(233,30,140,0.15);
  }

  .classes-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
    margin-top: 3rem;
  }

  .class-tiers { display: flex; flex-direction: column; gap: 1rem; }

  .tier {
    display: flex;
    gap: 1rem;
    padding: 1.2rem;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
    transition: border-color 0.2s;
  }

  .tier:hover { border-color: rgba(57,230,57,0.3); }

  .tier-num {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.2rem;
    color: var(--green);
    opacity: 0.4;
    min-width: 5rem;
  }

  .tier h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.3rem;
  }

  .tier p {
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }

  .classes-cta {
    background: rgba(57,230,57,0.05);
    border: 1px solid rgba(57,230,57,0.2);
    border-radius: 10px;
    padding: 2rem;
  }

  .classes-cta h3 {
    font-family: 'Bebas Neue', cursive;
    font-size: 2rem;
    margin-bottom: 0.8rem;
  }

  .classes-cta p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    font-size: 0.88rem;
  }

  .price-row:last-child { border-bottom: none; }
  .price-row span:first-child { color: rgba(255,255,255,0.65); }
  .price-row .price { font-family: 'Montserrat', sans-serif; font-weight: 700; color: var(--green); }

  /* ── COMMUNITY ── */
  .community { background: var(--navy-dark); }

  .community-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .testimonials { display: flex; flex-direction: column; gap: 1.2rem; }

  .testimonial {
    background: rgba(255,255,255,0.03);
    border-left: 3px solid var(--pink);
    border-radius: 0 6px 6px 0;
    padding: 1.2rem 1.4rem;
  }

  .testimonial p {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.72);
    font-style: italic;
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .testimonial-author {
    font-size: 1rem;
    font-weight: 600;
    color: var(--pink);
    letter-spacing: 0.06em;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-box {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
  }

  .stat-box .num {
    font-family: 'Bebas Neue', cursive;
    font-size: 3rem;
    color: var(--green);
    display: block;
    line-height: 1;
  }

  .stat-box .stat-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-top: 0.3rem;
    display: block;
  }

  /* ── LOYALTY ── */
  .loyalty {
    background: var(--navy);
    border-top: 1px solid rgba(57,230,57,0.12);
  }

  .loyalty-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .stamp-card {
    background: rgba(57,230,57,0.05);
    border: 1px solid rgba(57,230,57,0.2);
    border-radius: 12px;
    padding: 2rem;
  }

  .stamp-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .stamp-card-header h4 {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.4rem;
    color: var(--green);
  }

  .stamp-card-header span {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stamps {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .stamp {
    aspect-ratio: 1;
    border-radius: 50%;
    border: 2px solid rgba(57,230,57,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: rgba(57,230,57,0.3);
    font-weight: 700;
    transition: all 0.2s;
  }

  .stamp.filled {
    background: var(--green);
    border-color: var(--green);
    color: var(--navy-dark);
    font-size: 0.9rem;
  }

  .stamp-note {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    text-align: center;
  }

  .loyalty-text p {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .loyalty-perks { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 1.5rem; }

  .perk {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.88rem;
    color: rgba(255,255,255,0.7);
  }

  .perk-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--pink);
    flex-shrink: 0;
  }

  /* ── VENUES ── */
  .venues { background: var(--navy-dark); }

  .venues-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.2rem;
    margin-top: 3rem;
  }

  .venue-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .venue-card:hover { border-color: rgba(57,230,57,0.3); }

  .venue-icon {
    font-size: 1.8rem;
    margin-bottom: 0.8rem;
  }

  .venue-card h4 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.3rem;
  }

  .venue-card p {
    font-size: 1rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.5;
  }

  /* ── NEWSLETTER ── */
  .newsletter {
    background: linear-gradient(135deg, var(--navy) 0%, rgba(233,30,140,0.15) 50%, var(--navy) 100%);
    border-top: 1px solid rgba(233,30,140,0.2);
    border-bottom: 1px solid rgba(57,230,57,0.15);
    text-align: center;
    padding: 5rem 2rem;
  }

  .newsletter .section-title { font-size: clamp(2rem, 5vw, 3.5rem); }

  .newsletter p {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .newsletter-form {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    max-width: 480px;
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .newsletter-form input {
    flex: 1;
    min-width: 200px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    color: white;
    padding: 0.9rem 1.2rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    border-radius: 3px;
    outline: none;
    transition: border-color 0.2s;
  }

  .newsletter-form input:focus { border-color: var(--green); }
  .newsletter-form input::placeholder { color: rgba(255,255,255,0.35); }

  /* ── FOOTER ── */
  footer {
    background: var(--navy-dark);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 3rem 2rem 2rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }

  .footer-brand .logo {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.8rem;
    background: linear-gradient(90deg, var(--pink), var(--green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    margin-bottom: 0.8rem;
  }

  .footer-brand p {
    font-size: 1rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }

  .social-links {
    display: flex;
    gap: 0.8rem;
  }

  .social-link {
    width: 36px;
    height: 36px;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-family: 'Montserrat', sans-serif;
    transition: border-color 0.2s, color 0.2s;
  }

  .social-link:hover { border-color: var(--pink); color: var(--pink); }

  .footer-col h5 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col ul li a {
    font-size: 1rem;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-col ul li a:hover { color: var(--white); }

  .footer-bottom {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    nav { padding: 0.8rem 1.2rem; }
    .nav-links { display: none; }
    .nav-cta { font-size: 0.7rem; padding: 0.5rem 1rem; }
    .nav-logo { font-size: 1rem; }

    .why-grid,
    .classes-layout,
    .community-inner,
    .loyalty-inner { grid-template-columns: 1fr; gap: 2rem; }

    .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    section { padding: 3.5rem 1.2rem; }

    /* Hero */
    .hero { padding: 5rem 1.2rem 3rem; min-height: 90vh; }
    .hero-title .line1,
    .hero-title .line2 { font-size: clamp(3rem, 18vw, 6rem); }
    .hero-sub { font-size: 0.95rem; }
    .hero-btns { flex-direction: column; align-items: center; gap: 0.8rem; }
    .btn-primary, .btn-outline { width: 100%; text-align: center; }

    /* Section titles */
    .section-title { font-size: clamp(1.8rem, 8vw, 3rem); }

    /* Meet Your Teacher - stack photo above text */
    .about-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    .about-grid p { font-size: 1rem !important; }

    /* Events grid */
    .events-grid { grid-template-columns: 1fr; }

    /* Classes */
    .classes-layout { grid-template-columns: 1fr; }
    .classes-cta { padding: 1.5rem; }

    /* Testimonials - force single column */
    .testimonials { grid-template-columns: 1fr !important; gap: 1rem !important; }
    .testimonial p { font-size: 0.95rem !important; }

    /* Shop grid */
    div[style*='repeat(auto-fit,minmax(280px'] { grid-template-columns: 1fr !important; }

    /* Newsletter */
    .newsletter-form { flex-direction: column; }
    .newsletter-form input { min-width: unset; width: 100%; }

    /* Footer */
    .footer-brand p { font-size: 0.9rem; }
    .footer-col ul li a { font-size: 0.9rem; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }

    /* Pillar grid */
    .why-pillars { grid-template-columns: 1fr 1fr; }

    /* Price row */
    .price-row { font-size: 0.9rem; }

    /* Book now button */
    .classes-cta a.btn-primary { padding: 0.9rem 1rem; }
  }

  @media (max-width: 480px) {
    nav { padding: 0.7rem 1rem; }
    .footer-inner { grid-template-columns: 1fr; }
    .why-pillars { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .hero-title .line1,
    .hero-title .line2 { font-size: clamp(2.5rem, 20vw, 4rem); }
    .section-title { font-size: clamp(1.6rem, 10vw, 2.5rem); }
    .hero-eyebrow { font-size: 0.6rem; letter-spacing: 0.2em; }
    .tier { flex-direction: column; gap: 0.5rem; }
    .tier-num { font-size: 0.9rem; }
    .testimonials { grid-template-columns: 1fr !important; }
    .about-grid { grid-template-columns: 1fr !important; }
  }

  .tile-bg {
    position: relative;
  }
  .tile-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/webp;base64,");
    background-size: cover;
    background-position: center;
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  .tile-bg > * {
    position: relative;
    z-index: 1;
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">Las Vegas Mahjong</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#events">Events</a></li>
    <li><a href="#classes">Classes</a></li>
    <li><a href="#community">Testimonials</a></li>
    <li><a href="#shop">Shop</a></li>
    <li><a href="#" onclick="document.getElementById('contact-modal').style.display='flex';return false;">Contact</a></li>
  </ul>
  <a href="#events" class="nav-cta">Join an Event</a>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-bg"></div>

  <div class="hero-content">
    <p class="hero-eyebrow">Las Vegas · Community · Play</p>
    <h1 class="hero-title">
      <span class="line1">Las Vegas</span>
      <span class="line2">Mahjong</span>
    </h1>
    <p class="hero-sub">Las Vegas is bigger than the Strip — and so is our community. From Summerlin to Henderson, we're bringing players together across the whole Valley for lessons, open plays, leagues, tournaments, and more.</p>
    <div class="hero-btns">
      <a href="#events" class="btn-primary">See Upcoming Events</a>
      <a href="#classes" class="btn-outline">Learn to Play</a>
    </div>
  </div>

  <div class="scroll-hint">
    <div class="scroll-hint-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- WHY -->
<section class="why" id="about">
  <div class="container">
    <div class="why-grid">
      <div class="why-text reveal">
        <p class="section-label">Our Why</p>
        <h2 class="section-title">More Than a <span class="accent-green">Game</span></h2>
        <p>When I moved to Las Vegas almost 14 years ago, I was searching for the same thing so many of us are — <strong>community, connection, and real friendships</strong>. I found all of that at the mahjong table.</p>
        <p>Mahjong is a game of friendship, fun, strategy, and a little luck — brain-stimulating enough to keep you sharp, social enough to make you stay. Whether you're a total beginner or a seasoned player, there's a seat at the table for you.</p>
        <a href="#events" class="btn-primary" style="display:inline-block;margin-top:1.5rem;">Find Your Table</a>
      </div>
      <div class="why-pillars reveal">
        <div class="pillar">
          <div class="pillar-icon">🧠</div>
          <h4>Brain Health</h4>
          <p>Keep your mind sharp with every hand played.</p>
        </div>
        <div class="pillar">
          <div class="pillar-icon">💛</div>
          <h4>Friendship</h4>
          <p>Meet your new favorite people across the table.</p>
        </div>
        <div class="pillar">
          <div class="pillar-icon">🀄</div>
          <h4>Pure Fun</h4>
          <p>Every game is different. Every session a good time.</p>
        </div>
        <div class="pillar">
          <div class="pillar-icon">🌆</div>
          <h4>Vegas Community</h4>
          <p>Built for locals, transplants, visitors and newcomers alike.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MEET YOUR TEACHER -->
<section id="about" class="tile-bg" style="background:var(--navy-dark);padding:6rem 2rem;border-top:1px solid rgba(233,30,140,0.15);">
  <div class="container">
    <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:3rem;align-items:center;" class="about-grid">
      <div class="reveal">
        <div style="border-radius:12px;overflow:hidden;border:2px solid rgba(233,30,140,0.3);box-shadow:0 0 60px rgba(233,30,140,0.15);">
          <img src="data:image/jpeg;base64," alt="Shauna - Las Vegas Mahjong" style="width:100%;height:auto;object-fit:cover;display:block;">
        </div>
      </div>
      <div class="reveal">
        <p class="section-label">Meet Your Teacher</p>
        <h2 class="section-title">Hi, I'm <span class="accent-pink">Shauna!</span></h2>
        <p style="font-size:1.1rem;color:rgba(255,255,255,0.72);line-height:1.85;margin-bottom:1rem;">A Chicago suburbs girl turned Las Vegas local, wife, mom to two boys and three doodles, and proud Indiana Hoosier!</p>
        <p style="font-size:1.1rem;color:rgba(255,255,255,0.72);line-height:1.85;margin-bottom:1rem;">Almost 18 years ago, my grandma sat me down and taught me the game she loved and played most days of the week. I was hooked and started playing weekly with friends. She later gave me my very own set, and I've been playing ever since.</p>
        <p style="font-size:1.1rem;color:rgba(255,255,255,0.72);line-height:1.85;margin-bottom:1.8rem;">Over the years I started teaching friends, and in 2025 I turned that passion into Las Vegas Mahjong. My goal is simple: to share this beautiful, brain-stimulating, friendship-building game with as many people across the Valley as possible. I'd love to be your teacher.</p>
        <a href="#classes" class="btn-primary">Learn With Me</a>
      </div>
    </div>
  </div>
</section>

<!-- EVENTS -->
<section class="events" id="events">
  <div class="container">
    <div class="reveal">
      <p class="section-label">What's On</p>
      <h2 class="section-title">Upcoming <span class="accent-pink">Events</span></h2>
    </div>

    <div class="events-grid">
      <div class="event-card reveal">
        <div class="event-card-header">
          <h3>Open Play at Honey Salt</h3>
          <p class="event-meta">Sunday, March 29, 2026 · 3:00–5:00 PM · Honey Salt, Las Vegas</p>
        </div>
        <div class="event-card-body">
          <p>Join us for two hours of tiles, laughter, and great company at the beautiful Honey Salt. Gather with friends, meet fellow players, and enjoy a relaxed afternoon of mahjong. Your ticket includes a glass of wine or soft drink plus a raffle ticket for fun prizes. Come early, stay after, and make it a full outing — delicious food available for purchase from Honey Salt's menu.</p>
          <div class="event-price">
            <span class="price-amount">$45</span>
            <span class="price-label">per person · wine or soft drink + raffle ticket included</span>
          </div>
          <a href="https://partiful.com/e/wAs4XkKloghMYV1odE8p" target="_blank" class="btn-card">Reserve a Spot</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CLASSES -->
<section class="classes tile-bg" id="classes">
  <div class="container">
    <div class="reveal">
      <p class="section-label">Learn the Game</p>
      <h2 class="section-title">Mahjong <span class="accent-green">Lessons</span></h2>
    </div>
    <div class="classes-layout">
      <div class="class-tiers reveal">

        <div class="tier">
          <div class="tier-num">MAHJ101</div>
          <div>
            <h4>Absolute Beginners</h4>
            <p>Never touched a tile? No problem. We start from scratch — sorting the tiles, understanding the card, and playing your first hand.</p>
          </div>
        </div>
        <div class="tier">
          <div class="tier-num">MAHJ102</div>
          <div>
            <h4>Beyond the Basics</h4>
            <p>We'll start with a quick recap of everything covered in MAHJ101, then jump straight into the tiles — more hands, more practice, and more confidence at the table.</p>
          </div>
        </div>
        <div class="tier">
          <div class="tier-num">Teams & Tiles</div>
          <div>
            <h4>Large Groups, Corporate & Charity Events</h4>
            <p>From bachelorette parties to corporate team building, charity events, and more — private events for groups large and small, fully customized and endlessly fun.</p>
          </div>
        </div>
      </div>

      <div class="classes-cta reveal">
        <h3>Book a <span style="color:var(--green)">Lesson</span></h3>
        <p>Private or group lessons available at venues across Las Vegas, or virtually via Zoom. All levels welcome — we meet you where you are.</p>
        <div class="price-row">
          <span>Small Group (3–8 people)</span>
          <span class="price">$50 / person</span>
        </div>
        <div class="price-row">
          <span>Large Groups, Corporate & Charity Events</span>
          <span class="price">Pricing Varies</span>
        </div>


        <a href="#" class="btn-primary" style="display:block;text-align:center;margin-top:1.5rem;" onclick="document.getElementById('inquiry-modal').style.display='flex';return false;">Book Now</a>
      </div>
    </div>
  </div>
</section>

<!-- INQUIRY MODAL -->
<div id="inquiry-modal" style="display:none;position:fixed;inset:0;z-index:999;background:rgba(10,10,40,0.85);align-items:center;justify-content:center;padding:1.5rem;">
  <div style="background:#1a1b6e;border:1px solid rgba(57,230,57,0.3);border-radius:12px;padding:2.5rem;max-width:540px;width:100%;position:relative;max-height:90vh;overflow-y:auto;">
    <button onclick="document.getElementById('inquiry-modal').style.display='none'" style="position:absolute;top:1rem;right:1.2rem;background:none;border:none;color:rgba(255,255,255,0.4);font-size:1.5rem;cursor:pointer;line-height:1;">×</button>
    <p style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#39e639;margin-bottom:0.5rem;">Let's Play</p>
    <h3 style="font-family:'Bebas Neue',cursive;font-size:2rem;margin-bottom:0.4rem;">Book a <span style="color:#39e639;">Lesson</span></h3>
    <p style="font-size:1rem;color:rgba(255,255,255,0.5);margin-bottom:1.8rem;">Fill out the form below and I'll be in touch within 24 hours!</p>

    <div id="inquiry-success" style="display:none;text-align:center;padding:2rem 0;">
      <div style="font-size:2.5rem;margin-bottom:1rem;">🀄</div>
      <h4 style="font-family:'Bebas Neue',cursive;font-size:1.8rem;color:#39e639;margin-bottom:0.5rem;">You're on my radar!</h4>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.6);">Thanks for reaching out — I'll be in touch within 24 hours. Get ready to play!</p>
    </div>

    <form id="inquiry-form" onsubmit="handleInquirySubmit(event)" action="https://formspree.io/f/mwvrnjrb" method="POST">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        <div>
          <label style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;">First Name *</label>
          <input type="text" name="first_name" required placeholder="Jane" style="width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:white;padding:0.7rem 1rem;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:1.05rem;outline:none;">
        </div>
        <div>
          <label style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;">Last Name *</label>
          <input type="text" name="last_name" required placeholder="Smith" style="width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:white;padding:0.7rem 1rem;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:1.05rem;outline:none;">
        </div>
      </div>

      <div style="margin-bottom:1rem;">
        <label style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;">Email Address *</label>
        <input type="email" name="email" required placeholder="jane@email.com" style="width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:white;padding:0.7rem 1rem;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:1.05rem;outline:none;">
      </div>

      <div style="margin-bottom:1rem;">
        <label style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;">I'm Interested In *</label>
        <select name="interest" required style="width:100%;background:#1a1b6e;border:1px solid rgba(255,255,255,0.12);color:white;padding:0.7rem 1rem;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:1.05rem;outline:none;cursor:pointer;">
          <option value="" disabled selected>Select an option...</option>
          <option value="mahj101">MAHJ101 — Absolute Beginners</option>
          <option value="mahj102">MAHJ102 — Beyond the Basics</option>
          <option value="group">Teams & Tiles — Large Group / Corporate</option>
          <option value="private">Private 1-on-1 Lesson</option>
          <option value="other">Something Else</option>
        </select>
      </div>

      <div style="margin-bottom:1rem;">
        <label style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;">Number of People *</label>
        <select name="group_size" required style="width:100%;background:#1a1b6e;border:1px solid rgba(255,255,255,0.12);color:white;padding:0.7rem 1rem;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:1.05rem;outline:none;cursor:pointer;">
          <option value="" disabled selected>Select group size...</option>
          <option>Just me</option>
          <option>2 people</option>
          <option>3–4 people</option>
          <option>5–8 people</option>
          <option>9–15 people</option>
          <option>16+ people</option>
        </select>
      </div>

      <div style="margin-bottom:1rem;">
        <label style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;">Dates That Work For You</label>
        <textarea name="dates" rows="3" placeholder="e.g. Weekday evenings, Saturday mornings, any weekend in April..." style="width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:white;padding:0.7rem 1rem;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:1.05rem;outline:none;resize:vertical;"></textarea>
      </div>

      <div style="margin-bottom:1.5rem;">
        <label style="font-family:'Montserrat',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:0.4rem;">Anything Else?</label>
        <textarea name="message" rows="2" placeholder="Any questions, special requests, or details..." style="width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:white;padding:0.7rem 1rem;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:1.05rem;outline:none;resize:vertical;"></textarea>
      </div>

      <button type="submit" class="btn-primary" style="width:100%;text-align:center;padding:1rem;">Send My Inquiry</button>
    </form>
  </div>
</div>

<!-- COMMUNITY -->
<section class="community" id="community">
  <div class="container">
    <div class="reveal">
      <p class="section-label">Testimonials</p>
      <h2 class="section-title">What Players <span class="accent-pink">Are Saying</span></h2>
    </div>
    <div class="community-inner" style="margin-top:3rem;display:block;">
      <div class="testimonials reveal" style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;">
        <div class="testimonial">
